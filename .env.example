# Copy this file to `.env` in the project root before running `docker-compose up`.
# These values are passed to the backend container via `env_file`.

# --- External API credentials ------------------------------------------------
# Anthropic API key, used by the Claude model to generate grounded answers.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key, used to generate text embeddings for document chunks and queries.
OPENAI_API_KEY=sk-your-openai-key-here

# --- Vector store ----------------------------------------------------------------
# Filesystem directory (inside the backend container) where ChromaDB persists its data.
CHROMA_PERSIST_DIR=./chroma_data

# --- Model configuration -----------------------------------------------------------
# Anthropic Claude model used to generate answers.
LLM_MODEL=claude-3-5-haiku-20241022

# OpenAI embedding model used to vectorize document chunks and queries.
EMBEDDING_MODEL=text-embedding-3-small

# --- Chunking ------------------------------------------------------------------------
# Target maximum number of characters per document chunk.
CHUNK_SIZE=800

# Number of overlapping characters between consecutive chunks.
CHUNK_OVERLAP=150

# --- Retrieval -------------------------------------------------------------------------
# Number of chunks retrieved from the vector store per query.
TOP_K_RESULTS=5

# --- Uploads ---------------------------------------------------------------------------
# Maximum allowed upload size, in megabytes, for a single document.
MAX_FILE_SIZE_MB=20

# --- CORS --------------------------------------------------------------------------------
# JSON array of allowed origins for CORS requests from the frontend.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Frontend build (used by docker-compose to set the API base URL at build time) -------
VITE_API_URL=http://localhost:8000
